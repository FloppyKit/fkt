{
  "schema_version": 1,
  "name": "fkt-sparrow-real-v1",
  "description": "Real Sparrow PSBT golden matrix for FKT Ice Cold / Warm CLI signing validation (testnet only).",
  "network": "testnet",
  "layout": {
    "unsigned": "unsigned/",
    "sparrow_signed": "sparrow-signed/",
    "fkt_signed": "fkt-signed/",
    "legacy_unsigned": "Unsigned/v1/",
    "legacy_signed": "Signed/v1/"
  },
  "policy": {
    "p2sh_p2wpkh": "sign_if_key_matches",
    "p2wsh": "partial_sig_only",
    "p2tr_script_path": "reject_until_0.2",
    "notes": "Nested P2SH-P2WPKH: sign when BIP32 paths match seed. P2WSH: partial_sig only (not fully supported). Script-path Taproot: hard reject until script-path build (0.2)."
  },
  "seeds": {
    "call_release": {
      "kind": "bip39",
      "ref": "cli/tests/TEST_SEEDS.md",
      "env": "FKT_SEED_CALL_RELEASE",
      "usage": "New P2WPKH exports, all prior Taproot key-path, mixed p2wpkh+p2tr, script-path fixtures"
    },
    "nested_reward_parade": {
      "kind": "bip39",
      "ref": "cli/tests/TEST_SEEDS.md",
      "env": "FKT_SEED_NESTED",
      "usage": "Nested P2SH-P2WPKH Sparrow exports"
    },
    "legacy_p2wpkh_hex": {
      "kind": "bip32_seed_hex",
      "ref": "cli/tests/test_sparrow_real.py SEEDS[v1_p2wpkh]",
      "env": "FKT_SEED_LEGACY_P2WPKH_HEX",
      "usage": "Older v1_p2wpkh_* Sparrow exports (hex BIP32 seed, not mnemonic in TEST_SEEDS)",
      "note": "Do not invent a mnemonic; harness uses existing hex until re-export under call_release"
    },
    "unknown": {
      "kind": "unknown",
      "ref": null,
      "env": null,
      "usage": "Multisig / partial fixtures \u2014 document seed when productized"
    }
  },
